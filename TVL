-- ==================== ANTICHEAT BYPASS ====================

local function SetupAnticheatBypass()
    if BypassActive then return end
    BypassActive = true
    
    local BlockedNames = {
        AutoclickerDetected = true,
        ReportExploit = true,
        AntiCheatReport = true,
        ExploitDetected = true,
        CheatDetected = true,
        Kick = true
    }
    
    if hookmetamethod then
        OldNamecall = hookmetamethod(game, "__namecall", newcclosure(function(self, ...)
            local Method = getnamecallmethod()
            if Method == "FireServer" or Method == "InvokeServer" then
                local Success, Name = pcall(function() return self.Name end)
                if Success and BlockedNames[Name] then
                    return nil
                end
            end
            return OldNamecall(self, ...)
        end))
    end
    
    local ModuleScripts = ReplicatedStorage:FindFirstChild("ModuleScripts")
    local Flags = ModuleScripts and require(ModuleScripts:FindFirstChild("Flags") or {})
    
    if Flags and typeof(Flags) == "table" and Flags.GetFlag then
        OriginalGetFlag = Flags.GetFlag
        Flags.GetFlag = function(self, flagName, ...)
            local SpoofedFlags = {
                MaxClicksPerSecond = 999999,
                MacroMaxClicks = 999999,
                MacroKick = false,
                AutoclickerDetection = false,
                SpeedHackDetection = false,
                FlyHackDetection = false,
                TeleportDetection = false
            }
            if SpoofedFlags[flagName] ~= nil then
                return true, SpoofedFlags[flagName]
            end
            return OriginalGetFlag(self, flagName, ...)
        end
    end
    
    local mt = getrawmetatable(game)
    if mt then
        local oldIndex = mt.__index
        setreadonly(mt, false)
        mt.__index = newcclosure(function(t, k)
            if k == "Kick" and t == LocalPlayer then
                return function() end
            end
            return oldIndex(t, k)
        end)
        setreadonly(mt, true)
    end
end

-- ==================== ANTI SYSTEMS ====================

local function ToggleAntiFling(enabled)
    if AntiFlingConnection then
        AntiFlingConnection:Disconnect()
        AntiFlingConnection = nil
    end
    
    if enabled then
        AntiFlingConnection = RunService.Heartbeat:Connect(function()
            local character = LocalPlayer.Character
            if not character then return end
            local rootPart = character:FindFirstChild("HumanoidRootPart")
            if not rootPart then return end
            
            if rootPart.AssemblyLinearVelocity.Magnitude > 500 then
                rootPart.AssemblyLinearVelocity = Vector3.zero
                rootPart.AssemblyAngularVelocity = Vector3.zero
            end
        end)
    end
end

local function ToggleAntiRagdoll(enabled)
    local character = LocalPlayer.Character
    if not character then return end
    for _, obj in ipairs(character:GetDescendants()) do
        if obj:IsA("BallSocketConstraint") then
            obj.Enabled = not enabled
        end
    end
end

-- ==================== OPTIMIZED PLAYER SYSTEM ====================

local function GetPooledHitbox()
    for i = #HitboxPool, 1, -1 do
        local part = HitboxPool[i]
        if part and part.Parent == nil then
            table.remove(HitboxPool, i)
            return part
        end
    end
    local part = Instance.new("Part")
    part.Anchored = true; part.CanCollide = false
    part.CanQuery = false; part.CanTouch = false
    part.Material = Enum.Material.ForceField
    return part
end

local function ReturnHitboxToPool(part)
    if part then
        part.Parent = nil
        table.insert(HitboxPool, part)
    end
end

local function GetPooledESP()
    for i = #ESPPool, 1, -1 do
        local esp = ESPPool[i]
        if esp and esp.Parent == nil then
            table.remove(ESPPool, i)
            return esp
        end
    end
    local billboard = Instance.new("BillboardGui")
    billboard.AlwaysOnTop = true; billboard.Size = UDim2.new(0, 200, 0, 50)
    billboard.StudsOffset = Vector3.new(0, 3, 0)
    local label = Instance.new("TextLabel")
    label.BackgroundTransparency = 1; label.Size = UDim2.new(1, 0, 1, 0)
    label.Font = Config.ESPFont; label.TextSize = Config.ESPSize
    label.TextColor3 = Config.ESPColor; label.TextStrokeTransparency = 0.5
    label.Parent = billboard
    return billboard
end

local function ReturnESPToPool(esp)
    if esp then
        esp.Enabled = false
        esp.Parent = nil
        table.insert(ESPPool, esp)
    end
end

local function CleanupPlayer(player)
    local data = PlayerData[player]
    if not data then return end
    
    if data.HitboxPart then
        ReturnHitboxToPool(data.HitboxPart)
    end
    if data.ESPBillboard then
        ReturnESPToPool(data.ESPBillboard)
    end
    
    PlayerData[player] = nil
end

local function ResetPlayer(player)
    local data = PlayerData[player]
    if not data then return end
    
    local character = player.Character
    if character then
        local hrp = character:FindFirstChild("HumanoidRootPart")
        if hrp and data.OriginalSize then
            hrp.Size = data.OriginalSize
        end
    end
    
    if data.HitboxPart then
        ReturnHitboxToPool(data.HitboxPart)
        data.HitboxPart = nil
    end
    if data.ESPBillboard then
        ReturnESPToPool(data.ESPBillboard)
        data.ESPBillboard = nil
    end
end

-- ==================== COMBINED UPDATE LOOP ====================

local function UpdatePlayerVisuals(player)
    if player == LocalPlayer then return end
    
    local character = player.Character
    if not character then
        CleanupPlayer(player)
        return
    end
    
    local hrp = character:FindFirstChild("HumanoidRootPart")
    local head = character:FindFirstChild("Head")
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    
    if not hrp or not humanoid or humanoid.Health <= 0 then
        ResetPlayer(player)
        return
    end
    
    -- Initialize data
    if not PlayerData[player] then
        PlayerData[player] = {OriginalSize = hrp.Size}
    end
    local data = PlayerData[player]
    
    -- Team/Whitelist check
    local shouldSkip = WhitelistedPlayers[player.UserId] or 
                      (Config.TeamCheck and player.Team == LocalPlayer.Team)
    
    -- Hitbox Logic
    if Config.HitboxEnabled and not shouldSkip then
        if not data.OriginalSize then
            data.OriginalSize = hrp.Size
        end
        
        local targetSize = Vector3.new(Config.HitboxSize, Config.HitboxSize, Config.HitboxSize)
        if hrp.Size ~= targetSize then
            hrp.Size = targetSize
        end
        
        if Config.ShowHitbox then
            if not data.HitboxPart or data.HitboxPart.Parent == nil then
                data.HitboxPart = GetPooledHitbox()
                data.HitboxPart.Color = Config.HitboxColor
                data.HitboxPart.Transparency = Config.HitboxTransparency
                data.HitboxPart.Size = targetSize
                data.HitboxPart.Parent = hrp
            end
            if data.HitboxPart then
                data.HitboxPart.CFrame = hrp.CFrame
            end
        else
            if data.HitboxPart then
                ReturnHitboxToPool(data.HitboxPart)
                data.HitboxPart = nil
            end
        end
    else
        if data.OriginalSize and hrp.Size ~= data.OriginalSize then
            hrp.Size = data.OriginalSize
        end
        if data.HitboxPart then
            ReturnHitboxToPool(data.HitboxPart)
            data.HitboxPart = nil
        end
    end
    
    -- ESP Logic
    if Config.ESPEnabled and not shouldSkip and head then
        local distance = (Camera.CFrame.Position - head.Position).Magnitude
        if distance <= Config.MaxDistance then
            if not data.ESPBillboard or data.ESPBillboard.Parent == nil then
                data.ESPBillboard = GetPooledESP()
                data.ESPBillboard.Parent = head
                data.ESPBillboard.Adornee = head
            end
            
            local label = data.ESPBillboard:FindFirstChild("NameLabel")
            if label then
                local nameText = player.Name
                if Config.ShowDistance then
                    nameText = nameText .. " [" .. math.floor(distance) .. "m]"
                end
                if label.Text ~= nameText then
                    label.Text = nameText
                end
                if label.TextColor3 ~= Config.ESPColor then
                    label.TextColor3 = Config.ESPColor
                end
                if label.TextSize ~= Config.ESPSize then
                    label.TextSize = Config.ESPSize
                end
            end
            data.ESPBillboard.Enabled = true
        else
            if data.ESPBillboard then
                data.ESPBillboard.Enabled = false
            end
        end
    else
        if data.ESPBillboard then
            data.ESPBillboard.Enabled = false
        end
    end
end

-- Throttled update loop
local function StartUpdateLoop()
    if UpdateConnection then return end
    
    local function Loop()
        if not Config.HitboxEnabled and not Config.ESPEnabled then
            UpdateConnection = nil
            return
        end
        
        for _, player in ipairs(Players:GetPlayers()) do
            UpdatePlayerVisuals(player)
        end
        
        UpdateConnection = task.delay(Config.UpdateRate, Loop)
    end
    Loop()
end

local function StopUpdateLoop()
    if UpdateConnection then
        task.cancel(UpdateConnection)
        UpdateConnection = nil
    end
end

-- ==================== PLAYER HANDLING ====================

local function SetupPlayer(player)
    if player == LocalPlayer then return end
    
    player.CharacterAdded:Connect(function(char)
        task.wait(0.2)
        if Config.HitboxEnabled or Config.ESPEnabled then
            UpdatePlayerVisuals(player)
        end
    end)
    
    player.CharacterRemoving:Connect(function()
        ResetPlayer(player)
    end)
    
    if player.Character then
        task.spawn(function()
            task.wait(0.1)
            UpdatePlayerVisuals(player)
        end)
    end
end

