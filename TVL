-- Whitelist Tab
local WhitelistTab = Window:CreateTab("Whitelist", "user")

local WhitelistDisplay = WhitelistTab:CreateParagraph({
    Title = "Whitelisted Players",
    Content = "None"
})

local function UpdateWhitelistUI()
    task.spawn(function()
        local text = {}
        local count = 0
        for userId, _ in pairs(WhitelistedPlayers) do
            local name = CachedNames[userId]
            if not name then
                name = "User-" .. userId
                pcall(function()
                    name = Players:GetNameFromUserIdAsync(userId)
                    CachedNames[userId] = name
                end)
            end
            table.insert(text, "• " .. name)
            count = count + 1
        end
        WhitelistDisplay:Set(count > 0 and table.concat(text, "\n") or "None")
    end)
end

WhitelistTab:CreateInput({
    Name = "Add Player",
    PlaceholderText = "Username or UserId",
    RemoveTextAfterFocusLost = true,
    Callback = function(Text)
        task.spawn(function()
            local userId = tonumber(Text)
            if not userId then
                local success, result = pcall(function()
                    return Players:GetUserIdFromNameAsync(Text)
                end)
                if success then userId = result end
            end
            
            if userId then
                WhitelistedPlayers[userId] = true
                pcall(function()
                    CachedNames[userId] = Players:GetNameFromUserIdAsync(userId)
                end)
                
                for _, player in ipairs(Players:GetPlayers()) do
                    if player.UserId == userId then
                        ResetPlayer(player)
                    end
                end
                UpdateWhitelistUI()
                Notify("Whitelist", "Player added")
            else
                Notify("Error", "Player not found")
            end
        end)
    end
})

local Dropdown = WhitelistTab:CreateDropdown({
    Name = "Quick Add",
    Options = {"-- Select --"},
    CurrentOption = "-- Select --",
    Callback = function(Option)
        if Option == "-- Select --" then return end
        for _, player in ipairs(Players:GetPlayers()) do
            if player.Name == Option and not WhitelistedPlayers[player.UserId] then
                WhitelistedPlayers[player.UserId] = true
                CachedNames[player.UserId] = player.Name
                ResetPlayer(player)
                UpdateWhitelistUI()
                break
            end
        end
    end
})

local function RefreshDropdown()
    local options = {"-- Select --"}
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and not WhitelistedPlayers[player.UserId] then
            table.insert(options, player.Name)
        end
    end
    Dropdown:Refresh(options)
end

Players.PlayerAdded:Connect(function() task.delay(1, RefreshDropdown) end)
Players.PlayerRemoving:Connect(RefreshDropdown)

WhitelistTab:CreateButton({
    Name = "Clear Whitelist",
    Callback = function()
        table.clear(WhitelistedPlayers)
        table.clear(CachedNames)
        UpdateWhitelistUI()
        RefreshDropdown()
        Notify("Whitelist", "Cleared")
    end
})

