local function IsFriend(player)
    if not player or not player.UserId then return false end
    if FriendsCache[player.UserId] ~= nil then return FriendsCache[player.UserId] end
    
    local success, result = pcall(function()
        return LocalPlayer:IsFriendsWith(player.UserId)
    end)
    
    FriendsCache[player.UserId] = success and result == true
    return FriendsCache[player.UserId]
end

local function GetCharacterCenter(character)
    if not character then return nil end
    local hrp = character:FindFirstChild("HumanoidRootPart")
    local head = character:FindFirstChild("Head")
    if hrp then
        return hrp.Position
    elseif head then
        return head.Position
    end
    return nil
end

local function GetClosestPlayerToMouse(maxDistance)
    local closestPlayer = nil
    local shortestDistance = maxDistance or math.huge
    local mousePos = UserInputService:GetMouseLocation()
    
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local character = player.Character
            local humanoid = character:FindFirstChildOfClass("Humanoid")
            local targetPart = character:FindFirstChild(Config.SilentAim.Mode) or character:FindFirstChild("HumanoidRootPart")
            
            if humanoid and humanoid.Health > 0 and targetPart then
                if Config.HitboxExpansion.ExcludeFriends and IsFriend(player) then
                    continue
                end
                
                local screenPos, onScreen = Camera:WorldToViewportPoint(targetPart.Position)
                if onScreen then
                    local distance = (Vector2.new(screenPos.X, screenPos.Y) - mousePos).Magnitude
                    if distance < shortestDistance then
                        -- Wall check
                        if Config.SilentAim.WallCheck then
                            local raycastParams = RaycastParams.new()
                            raycastParams.FilterDescendantsInstances = {LocalPlayer.Character, character}
                            raycastParams.FilterType = Enum.RaycastFilterType.Blacklist
                            
                            local direction = (targetPart.Position - Camera.CFrame.Position).Unit
                            local result = workspace:Raycast(Camera.CFrame.Position, direction * 1000, raycastParams)
                            
                            if result then
                                continue
                            end
                        end
                        
                        shortestDistance = distance
                        closestPlayer = player
                    end
                end
            end
        end
    end
    
    return closestPlayer
end

-- ==================== ANTICHEAT & BYPASS ====================

local function SetupAnticheatBypass()
    if not getgenv().TVL2_AnticheatBypassed then
        getgenv().TVL2_AnticheatBypassed = true
        
        -- Intercept suspicious remote calls
        local InterceptCalls = {
            AutoclickerDetected = true,
            AbilityActivated____ = true,
            RobloxMessageService = true,
            BuyItemFromShop = true,
            ReportExploit = true,
            AntiCheat = true,
            Check = true,
            Verify = true
        }
        
        -- Hook namecall
        local OldNamecall
        OldNamecall = hookmetamethod(game, "__namecall", newcclosure(function(self, ...)
            local Method = getnamecallmethod()
            if Method == "FireServer" then
                local Success, Name = pcall(function() return self.Name end)
                if Success and InterceptCalls[Name] then
                    return nil
                end
            elseif Method == "InvokeServer" then
                local Success, Name = pcall(function() return self.Name end)
                if Success and InterceptCalls[Name] then
                    return nil
                end
            end
            return OldNamecall(self, ...)
        end))
        
        -- Hook Flags
        if Flags then
            local OriginalGetFlag = Flags.GetFlag
            Flags.GetFlag = function(self, flagName, ...)
                if flagName == "MaxClicksPerSecond" or flagName == "MacroMaxClicks" then
                    return true, 999999
                elseif flagName == "MacroKick" or flagName == "AutoclickerDetection" then
                    return true, false
                elseif flagName == "SpeedHackDetection" or flagName == "FlyHackDetection" then
                    return true, false
                elseif flagName == "TeleportDetection" then
                    return true, false
                end
                return OriginalGetFlag(self, flagName, ...)
            end
        end
        
        -- Hook other detection methods
        local mt = getrawmetatable(game)
        if mt then
            local oldIndex = mt.__index
            setreadonly(mt, false)
            mt.__index = newcclosure(function(t, k)
                if k == "Kick" and t == LocalPlayer then
                    return function() end
                end
                return oldIndex(t, k)
            end)
            setreadonly(mt, true)
        end
        
        Notify("Anticheat", "All bypasses initialized")
    end
end

local function SetupAntiFling()
    if Connections.AntiFling then
        Connections.AntiFling:Disconnect()
    end
    
    if Config.Anticheat.AntiFling then
        Connections.AntiFling = RunService.Heartbeat:Connect(function()
            local character = LocalPlayer.Character
            if character then
                local rootPart = character:FindFirstChild("HumanoidRootPart")
                if rootPart then
                    local linearVel = rootPart.AssemblyLinearVelocity.Magnitude
                    local angularVel = rootPart.AssemblyAngularVelocity.Magnitude
                    
                    if linearVel > 500 or angularVel > 500 then
                        rootPart.AssemblyLinearVelocity = Vector3.zero
                        rootPart.AssemblyAngularVelocity = Vector3.zero
                        rootPart.CFrame = CFrame.new(rootPart.Position)
                    end
                end
            end
        end)
    end
end

