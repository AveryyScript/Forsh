local function SetupHitboxExpansion()
    if OriginalFunctions.Hitscan then
        HitDetection.Hitscan = OriginalFunctions.Hitscan
    else
        OriginalFunctions.Hitscan = HitDetection.Hitscan
    end
    
    HitDetection.Hitscan = function(self)
        if not Config.HitboxExpansion.Enabled then
            return OriginalFunctions.Hitscan(self)
        end
        
        if not self._character or not self._character.PrimaryPart then
            return nil
        end
        
        local origin = self._character.PrimaryPart.Position
        local closestCharacter = nil
        local maxDistance = Config.HitboxExpansion.Size
        
        for _, player in ipairs(Players:GetPlayers()) do
            if player ~= LocalPlayer then
                if not (Config.HitboxExpansion.ExcludeFriends and IsFriend(player)) then
                    local char = player.Character
                    if char then
                        local aimPart = char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Head") or char.PrimaryPart
                        if aimPart then
                            local distance = (origin - aimPart.Position).Magnitude
                            if distance <= maxDistance and distance <= (self._range or 50) * 2 then
                                closestCharacter = char
                                break
                            end
                        end
                    end
                end
            end
        end
        
        return closestCharacter or OriginalFunctions.Hitscan(self)
    end
end

local function CreateFOVCircle()
    if FOV_Circle then
        FOV_Circle:Remove()
    end
    
    FOV_Circle = Drawing.new("Circle")
    FOV_Circle.Thickness = 1
    FOV_Circle.NumSides = 100
    FOV_Circle.Radius = Config.SilentAim.FOV
    FOV_Circle.Filled = false
    FOV_Circle.Visible = false
    FOV_Circle.ZIndex = 999
    FOV_Circle.Color = Color3.fromRGB(255, 255, 255)
    FOV_Circle.Transparency = 1
end

local function UpdateFOVCircle()
    if not FOV_Circle then return end
    
    if Config.SilentAim.Enabled then
        FOV_Circle.Visible = true
        FOV_Circle.Position = UserInputService:GetMouseLocation()
        FOV_Circle.Radius = Config.SilentAim.FOV
        
        if SilentAimTarget then
            FOV_Circle.Color = Color3.fromRGB(0, 255, 0)
        else
            FOV_Circle.Color = Color3.fromRGB(255, 255, 255)
        end
    else
        FOV_Circle.Visible = false
    end
end

local function SetupSilentAim()
    if Connections.SilentAim then
        Connections.SilentAim:Disconnect()
    end
    
    if Config.SilentAim.Enabled then
        CreateFOVCircle()
        Connections.SilentAim = RunService.RenderStepped:Connect(function()
            SilentAimTarget = GetClosestPlayerToMouse(Config.SilentAim.FOV)
            UpdateFOVCircle()
        end)
    else
        if FOV_Circle then
            FOV_Circle.Visible = false
        end
        SilentAimTarget = nil
    end
end

-- ==================== ESP SYSTEM ====================

local function CreateESPObject(player)
    local espObject = {
        Player = player,
        Box = nil,
        NameLabel = nil,
        DistanceLabel = nil,
        HealthBar = nil,
        HealthBarBackground = nil,
        Connection = nil
    }
    
    -- Create UI elements
    local function CreateDrawing()
        -- Box
        espObject.Box = Drawing.new("Square")
        espObject.Box.Thickness = 1
        espObject.Box.Filled = false
        espObject.Box.Visible = false
        
        -- Name
        espObject.NameLabel = Drawing.new("Text")
        espObject.NameLabel.Size = 14
        espObject.NameLabel.Center = true
        espObject.NameLabel.Outline = true
        espObject.NameLabel.Visible = false
        
        -- Distance
        espObject.DistanceLabel = Drawing.new("Text")
        espObject.DistanceLabel.Size = 12
        espObject.DistanceLabel.Center = true
        espObject.DistanceLabel.Outline = true
        espObject.DistanceLabel.Visible = false
        
        -- Health bar background
        espObject.HealthBarBackground = Drawing.new("Square")
        espObject.HealthBarBackground.Filled = true
        espObject.HealthBarBackground.Visible = false
        
        -- Health bar
        espObject.HealthBar = Drawing.new("Square")
        espObject.HealthBar.Filled = true
        espObject.HealthBar.Visible = false
    end
    
    CreateDrawing()
    
    -- Update function
    espObject.Connection = RunService.RenderStepped:Connect(function()
        if not Config.ESP.Enabled or not player.Character then
            espObject.Box.Visible = false
            espObject.NameLabel.Visible = false
            espObject.DistanceLabel.Visible = false
            espObject.HealthBar.Visible = false
            espObject.HealthBarBackground.Visible = false
            return
        end
        
        local character = player.Character
        local humanoid = character:FindFirstChildOfClass("Humanoid")
        local hrp = character:FindFirstChild("HumanoidRootPart")
        
        if not humanoid or not hrp or humanoid.Health <= 0 then
            espObject.Box.Visible = false
            espObject.NameLabel.Visible = false
            espObject.DistanceLabel.Visible = false
            espObject.HealthBar.Visible = false
            espObject.HealthBarBackground.Visible = false
            return
        end
        
        -- Team check
        if Config.ESP.TeamCheck and player.Team == LocalPlayer.Team then
            espObject.Box.Visible = false
            espObject.NameLabel.Visible = false
            espObject.DistanceLabel.Visible = false
            espObject.HealthBar.Visible = false
            espObject.HealthBarBackground.Visible = false
            return
        end
        
        local pos, onScreen = Camera:WorldToViewportPoint(hrp.Position)
        local distance = (hrp.Position - Camera.CFrame.Position).Magnitude
        
        if not onScreen or distance > Config.ESP.MaxDistance then
            espObject.Box.Visible = false
            espObject.NameLabel.Visible = false
            espObject.DistanceLabel.Visible = false
            espObject.HealthBar.Visible = false
            espObject.HealthBarBackground.Visible = false
            return
        end
        
        -- Calculate box size based on distance
        local size = 2000 / distance
        local width = size * 0.6
        local height = size * 1.2
        
        local boxX = pos.X - width / 2
        local boxY = pos.Y - height / 2
        
        -- Color based on team/friend
        local color = Color3.fromRGB(255, 50, 50) -- Enemy
        if IsFriend(player) then
            color = Color3.fromRGB(50, 255, 50) -- Friend
        elseif player.Team == LocalPlayer.Team then
            color = Color3.fromRGB(50, 150, 255) -- Teammate
        end
        
        -- Update box
        if Config.ESP.Boxes then
            espObject.Box.Visible = true
            espObject.Box.Size = Vector2.new(width, height)
            espObject.Box.Position = Vector2.new(boxX, boxY)
            espObject.Box.Color = color
        else
            espObject.Box.Visible = false
        end
        
        -- Update name
        if Config.ESP.Names then
            espObject.NameLabel.Visible = true
            espObject.NameLabel.Text = player.DisplayName
            espObject.NameLabel.Position = Vector2.new(pos.X, boxY - 15)
            espObject.NameLabel.Color = color
        else
            espObject.NameLabel.Visible = false
        end
        
        -- Update distance
        if Config.ESP.Distance then
            espObject.DistanceLabel.Visible = true
            espObject.DistanceLabel.Text = math.floor(distance) .. "m"
            espObject.DistanceLabel.Position = Vector2.new(pos.X, boxY + height + 2)
            espObject.DistanceLabel.Color = Color3.fromRGB(255, 255, 255)
        else
            espObject.DistanceLabel.Visible = false
        end
        
        -- Update health bar
        if Config.ESP.Health then
            local healthPercent = humanoid.Health / humanoid.MaxHealth
            local barHeight = height * healthPercent
            
            espObject.HealthBarBackground.Visible = true
            espObject.HealthBarBackground.Size = Vector2.new(4, height)
            espObject.HealthBarBackground.Position = Vector2.new(boxX - 8, boxY)
            espObject.HealthBarBackground.Color = Color3.fromRGB(50, 50, 50)
            
            espObject.HealthBar.Visible = true
            espObject.HealthBar.Size = Vector2.new(4, barHeight)
            espObject.HealthBar.Position = Vector2.new(boxX - 8, boxY + height - barHeight)
            espObject.HealthBar.Color = Color3.fromRGB(255 - (255 * healthPercent), 255 * healthPercent, 0)
        else
            espObject.HealthBar.Visible = false
            espObject.HealthBarBackground.Visible = false
        end
    end)
    
    return espObject
end

local function SetupESP()
    -- Clear existing ESP
    for _, esp in pairs(ESPObjects) do
        if esp.Connection then
            esp.Connection:Disconnect()
        end
        if esp.Box then esp.Box:Remove() end
        if esp.NameLabel then esp.NameLabel:Remove() end
        if esp.DistanceLabel then esp.DistanceLabel:Remove() end
        if esp.HealthBar then esp.HealthBar:Remove() end
        if esp.HealthBarBackground then esp.HealthBarBackground:Remove() end
    end
    ESPObjects = {}
    
    if not Config.ESP.Enabled then return end
    
    -- Create ESP for existing players
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            ESPObjects[player] = CreateESPObject(player)
        end
    end
    
    -- Handle new players
    Players.PlayerAdded:Connect(function(player)
        if Config.ESP.Enabled then
            ESPObjects[player] = CreateESPObject(player)
        end
    end)
    
    Players.PlayerRemoving:Connect(function(player)
        if ESPObjects[player] then
            if ESPObjects[player].Connection then
                ESPObjects[player].Connection:Disconnect()
            end
            if ESPObjects[player].Box then ESPObjects[player].Box:Remove() end
            if ESPObjects[player].NameLabel then ESPObjects[player].NameLabel:Remove() end
            if ESPObjects[player].DistanceLabel then ESPObjects[player].DistanceLabel:Remove() end
            if ESPObjects[player].HealthBar then ESPObjects[player].HealthBar:Remove() end
            if ESPObjects[player].HealthBarBackground then ESPObjects[player].HealthBarBackground:Remove() end
            ESPObjects[player] = nil
        end
    end)
end

